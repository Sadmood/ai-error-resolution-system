{
  "icon": "icon.png",
  "name": "error-expander-multilingual",
  "displayName": "error-expander-multilingual",
  "description": "Myprojectt",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "error-expander.explain",
        "title": "Explain Error"
      }
    ],
    "configuration": {
      "title": "Error Expander Settings",
      "properties": {
        "errorExpander.targetLanguage": {
          "type": "string",
          "default": "Thai",
          "enum": [
            "Thai",
            "English",
            "Japanese",
            "Chinese",
            "Korean",
            "French",
            "German",
            "Spanish",
            "Italian",
            "Russian",
            "Portuguese",
            "Arabic",
            "Hindi"
          ],
          "description": "เลือกภาษาที่ต้องการให้ AI แปลและอธิบาย (Select the language you want the AI to translate and explain)"
        },"errorExpander.tone": {
  "type": "string",
  "default": "Teacher",
  "enum": [
    "Teacher",
    "Senior Dev",
    "ELI5"
  ],
  "description": "เลือกบุคลิก AI: Teacher (ครูใจดี), Senior Dev (รุ่นพี่โหด), ELI5 (สอนเด็ก 5 ขวบ)"
}
      }
    },
    "keybindings": [
      {
        "command": "error-expander.explain",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.104.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
